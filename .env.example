# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Get both URLs from Neon dashboard → your project → Connection Details → Prisma
# DATABASE_URL uses the pooled connection (for app queries)
# DIRECT_URL uses the direct connection (for Prisma migrations)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/opentoolkit?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/opentoolkit?sslmode=require"

# ── Clerk Auth ─────────────────────────────────────────────────────────────────
# Get from: clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Create a fine-grained PAT at: github.com/settings/tokens
# Permissions needed: read:repo metadata (public repos only is fine)
GITHUB_TOKEN="ghp_..."

# ── Groq ───────────────────────────────────────────────────────────────────────
# Get from: console.groq.com → API Keys
GROQ_API_KEY="gsk_..."

# ── Redis (local dev — Docker handles this automatically) ──────────────────────
REDIS_URL="redis://localhost:6379"